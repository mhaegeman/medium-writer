# Anthropic API key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Medium Integration Token (optional - for publishing directly to Medium)
# Get yours at https://medium.com/me/settings > Integration tokens
MEDIUM_INTEGRATION_TOKEN=your_medium_token_here

# Medium Author ID (optional - auto-fetched if token is set)
MEDIUM_AUTHOR_ID=

# Default publication status: draft, public, or unlisted
MEDIUM_PUBLISH_STATUS=draft

# Claude model to use for writing
# Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# Output directory for generated articles
ARTICLES_DIR=articles
